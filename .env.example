# Olympic Hub - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================================================
# OPEN GREECE API
# ============================================================================

# API Endpoints (DO NOT CHANGE)
OPENGREECE_PULL_URL=https://online.open-greece.com/nsCallWebServices/handlerequest.aspx
OPENGREECE_PUSH_URL=https://online.open-greece.com/nsCallWebService_Push/handlerequest.aspx

# Authentication (Production Credentials)
OPENGREECE_USERNAME=your_username_here
OPENGREECE_PASSWORD=your_password_here

# FTP Access (Production Credentials)
OPENGREECE_FTP_HOST=ftp.open-greece.com
OPENGREECE_FTP_PORT=21
OPENGREECE_FTP_USERNAME=your_ftp_username_here
OPENGREECE_FTP_PASSWORD=your_ftp_password_here

# Settings
OPENGREECE_USE_MOCK=false


# ============================================================================
# TCT API (Existing)
# ============================================================================

TCT_API_URL=https://imc-dev.tct.travel/api/v1
TCT_USERNAME=your_username_here
TCT_PASSWORD=your_password_here
TCT_USE_MOCK=true

# ============================================================================
# SOLVEX API (Master-Interlook)
# ============================================================================

# Test Environment
SOLVEX_API_URL=https://evaluation.solvex.bg/iservice/integrationservice.asmx
SOLVEX_LOGIN=your_solvex_username
SOLVEX_PASSWORD=your_solvex_password
SOLVEX_USE_MOCK=false

# Production Environment (uncomment when ready)
# SOLVEX_PROD_URL=your_production_url_here
# SOLVEX_PROD_LOGIN=your_production_login_here
# SOLVEX_PROD_PASSWORD=your_production_password_here

# ============================================================================
# MARS API (Neolab)
# ============================================================================

# Production Environment
MARS_BASE_URL=https://yourMarsDomain
MARS_USERNAME=your_mars_username
MARS_PASSWORD=your_mars_password

# Mock Server (for testing without credentials)
# MARS_USE_MOCK=true

# ============================================================================
# ORS API (Open Reservation System)
# ============================================================================

# Production Environment
ORS_API_KEY=your_ors_api_key_here
ORS_BASE_URL=https://api.ors.si/crs/v2

# Settings
ORS_USE_MOCK=false

# ============================================================================
# SUPABASE
# ============================================================================

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================================================
# GOOGLE GEMINI AI
# ============================================================================

GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# GOOGLE MAPS API
# ============================================================================

# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable the following APIs:
# - Maps JavaScript API
# - Places API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# AMADEUS FLIGHT API
# ============================================================================

# Get your credentials at: https://developers.amadeus.com/
# Test Environment (for development)
AMADEUS_API_KEY=your_test_api_key_here
AMADEUS_API_SECRET=your_test_api_secret_here
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Production Environment (uncomment when ready for production)
# AMADEUS_API_KEY=your_production_api_key_here
# AMADEUS_API_SECRET=your_production_api_secret_here
# AMADEUS_BASE_URL=https://api.amadeus.com

# ============================================================================
# KIWI.COM TEQUILA API (Future Integration)
# ============================================================================

# KIWI_API_KEY=your_kiwi_api_key_here
# KIWI_BASE_URL=https://tequila-api.kiwi.com

# ============================================================================
# DUFFEL API (Future Integration)
# ============================================================================

# DUFFEL_API_TOKEN=your_duffel_token_here
# DUFFEL_BASE_URL=https://api.duffel.com

# ============================================================================
# TRAVELFUSION API (Future Integration)
# ============================================================================

# TRAVELFUSION_USERNAME=your_username_here
# TRAVELFUSION_PASSWORD=your_password_here
# TRAVELFUSION_BASE_URL=https://xml.travelfusion.com

# ============================================================================
# APPLICATION
# ============================================================================

VITE_APP_NAME=Olympic Hub
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
