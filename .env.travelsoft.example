# ============================================================
# Travelsoft NDC API Konfiguracija
# ============================================================
# Kontaktirajte Travelsoft (contacts@travelsoft.fr) za dobijanje:
# - URL test/production okruženja
# - Username i Password
# - IP Whitelist (vaše server IP adrese)

VITE_TRAVELSOFT_BASE_URL=https://YOUR_SERVER/ndc/ws/rest/19.2
VITE_TRAVELSOFT_USERNAME=your_username_here
VITE_TRAVELSOFT_PASSWORD=your_password_here
VITE_TRAVELSOFT_PROVIDER=SWITCHALLINONE
VITE_TRAVELSOFT_API_VERSION=1.0

# ============================================================
# Amadeus API Konfiguracija (ako se koristi)
# ============================================================
# VITE_AMADEUS_API_KEY=your_amadeus_key
# VITE_AMADEUS_API_SECRET=your_amadeus_secret
# VITE_AMADEUS_BASE_URL=https://test.api.amadeus.com
